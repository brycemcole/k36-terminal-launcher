[Unit]
Description=K36 Terminal Launcher
After=firstboot.service

[Service]
Type=simple
User=ark
WorkingDirectory=/home/ark
Environment=TERM=linux
Environment=XDG_RUNTIME_DIR=/run/user/1002
TTYPath=/dev/tty1
StandardInput=tty
StandardOutput=tty
StandardError=journal+console
ExecStart=/usr/local/bin/k36-terminal-launcher
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
